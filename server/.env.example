NODE_ENV=development
PORT=5000

MONGO_URI=dummy_mongodb_uri

SERVER_URL=http://localhost:5000
SERVER_PUBLIC_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

NLP_SERVICE_URL=http://127.0.0.1:8000
NLP_SERVICE_BASE=http://127.0.0.1:8000

JWT_SECRET=dummy_jwt_secret

ACCESS_TOKEN_SECRET=dummy_access_token_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=dummy_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=7d

REFRESH_COOKIE_NAME=refreshToken
ACCESS_COOKIE_NAME=accessToken
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_ALLOW_SELF_SIGNED=false
SMTP_USER=dummy_email@gmail.com
SMTP_PASS=dummy_app_password
MAIL_FROM=dummy_email@gmail.com

GOOGLE_CLIENT_ID=dummy_google_client_id

OPENROUTER_API_KEY=dummy_openrouter_key
ASSEMBLY_API_KEY=dummy_assembly_key
GROQ_API_KEY=dummy_groq_key

REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

CLOUDINARY_CLOUD_NAME=dummy_cloud_name
CLOUDINARY_API_KEY=dummy_api_key
CLOUDINARY_API_SECRET=dummy_api_secret
STORAGE_PROVIDER=cloudinary